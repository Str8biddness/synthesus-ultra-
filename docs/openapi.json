{
  "openapi": "3.1.0",
  "info": {
    "title": "Synthesus 5 CHAL API",
    "description": "Legacy-compatible Synthesus query and control API for the active Synthesus 5 CHAL runtime. The public query path currently exposes generation-spine, cognitive, RAG, kernel, and amplification telemetry; Cognitive Hypervisor and CGPU traces are documented as CHAL contracts until they are wired into this endpoint.",
    "version": "5.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/query": {
      "post": {
        "summary": "Query",
        "operationId": "query_query_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/stream": {
      "get": {
        "summary": "Stream",
        "operationId": "stream_stream_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Q"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/characters": {
      "get": {
        "summary": "Characters",
        "operationId": "characters_characters_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/process": {
      "post": {
        "summary": "Process",
        "operationId": "process_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/world_state": {
      "get": {
        "summary": "Get World State",
        "description": "Get current world state flags.",
        "operationId": "get_world_state_world_state_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      },
      "post": {
        "summary": "Set World State",
        "description": "Set world state flags for all cognitive engines.",
        "operationId": "set_world_state_world_state_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "type": "object",
                "title": "Flags"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/cognitive_stats": {
      "get": {
        "summary": "Cognitive Stats",
        "description": "Get statistics from all active cognitive engines.",
        "operationId": "cognitive_stats_cognitive_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "QueryRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query",
            "default": ""
          },
          "q": {
            "type": "string",
            "title": "Q",
            "default": ""
          },
          "text": {
            "type": "string",
            "title": "Text",
            "default": ""
          },
          "stream": {
            "type": "boolean",
            "title": "Stream",
            "default": false
          },
          "context": {
            "type": "string",
            "title": "Context",
            "default": ""
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "default": "left",
            "description": "Legacy-compatible processing mode: auto|cognitive|rag|pattern. Synthesus 5 CHAL routing is represented in debug telemetry until the Cognitive Hypervisor is wired into the public query path."
          },
          "character": {
            "type": "string",
            "title": "Character",
            "default": ""
          },
          "player_id": {
            "type": "string",
            "title": "Player Id",
            "default": "default"
          }
        },
        "type": "object",
        "title": "QueryRequest"
      },
      "QueryResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "module": {
            "type": "string",
            "title": "Module"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "kernel",
            "description": "Runtime source that produced the response, such as zo_kernel, symbolic_core, cognitive, synthesus_master, rag, or fallback."
          },
          "character": {
            "type": "string",
            "title": "Character",
            "default": ""
          },
          "pattern_id": {
            "type": "string",
            "title": "Pattern Id",
            "default": ""
          },
          "emotion": {
            "type": "string",
            "title": "Emotion",
            "default": ""
          },
          "relationship": {
            "additionalProperties": true,
            "type": "object",
            "title": "Relationship",
            "default": {}
          },
          "debug": {
            "additionalProperties": true,
            "type": "object",
            "title": "Debug",
            "default": {},
            "description": "Optional implementation telemetry returned only when include_debug is true. Current keys include kernel_triggered, symbolic_triggered, trace, rag, ml_swarm, and fallback diagnostics. Future Synthesus 5 wiring should place Cognitive Hypervisor and CGPU candidate-set trace records here without changing the stable response envelope."
          }
        },
        "type": "object",
        "required": [
          "response",
          "confidence",
          "module"
        ],
        "title": "QueryResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "CGPUFrame": {
        "type": "object",
        "title": "CGPUFrame",
        "description": "CHAL input frame for the chal://cgpu/render device implemented in packages/reasoning/generation/cgpu.py.",
        "required": [
          "frame_id",
          "trace_id",
          "query",
          "plan"
        ],
        "properties": {
          "frame_id": {
            "type": "string"
          },
          "trace_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "plan": {
            "additionalProperties": true,
            "type": "object",
            "description": "Serialized ResponsePlan with intent, safety level, key points, required phrases, forbidden phrases, and domain/style constraints."
          },
          "grounded_state": {
            "additionalProperties": true,
            "type": "object"
          },
          "mode": {
            "type": "string",
            "default": "general",
            "description": "Render mode such as general, npc, persona, dialogue, business, or business_bot."
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "critic_passes": {
            "type": "integer",
            "minimum": 0,
            "default": 1
          },
          "constraints": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "persona": {
            "additionalProperties": true,
            "type": "object"
          },
          "provenance": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          }
        }
      },
      "CGPUOutputFrame": {
        "type": "object",
        "title": "CGPUOutputFrame",
        "description": "Candidate-set output from the chal://cgpu/render device. The selected text is still subject to hypervisor or arbiter safety approval.",
        "required": [
          "frame_id",
          "parent_frame_id",
          "trace_id",
          "device",
          "kind",
          "candidates",
          "confidence",
          "cost",
          "trace"
        ],
        "properties": {
          "frame_id": {
            "type": "string"
          },
          "parent_frame_id": {
            "type": "string"
          },
          "trace_id": {
            "type": "string"
          },
          "device": {
            "type": "string",
            "const": "chal://cgpu/render"
          },
          "kind": {
            "type": "string",
            "const": "candidate_set"
          },
          "candidates": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "selected_candidate_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "selected_text": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "cost": {
            "additionalProperties": true,
            "type": "object"
          },
          "trace": {
            "additionalProperties": true,
            "type": "object",
            "description": "Includes mode, constraints, provenance, grounding_required, and safety_arbitration_required."
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        }
      }
    }
  }
}
