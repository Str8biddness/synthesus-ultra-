{
  "openapi": "3.1.0",
  "info": {
    "title": "Synthesus 5 CHAL API",
    "description": "Legacy-compatible Synthesus query and control API for the active Synthesus 5 CHAL runtime. The public query path currently exposes explicit Cognitive Hypervisor routing through mode=chal plus generation-spine, cognitive, RAG, kernel, and amplification telemetry. CognitiveHypervisorTrace documents debug.cognitive_hypervisor for CHAL requests, including QuadBrainArbitration when route=quad_brain_path; CGPU traces are documented as CHAL contracts until candidate-set payloads are surfaced by this endpoint.",
    "version": "5.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/query": {
      "post": {
        "summary": "Query",
        "operationId": "query_query_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/stream": {
      "get": {
        "summary": "Stream",
        "operationId": "stream_stream_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Q"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/characters": {
      "get": {
        "summary": "Characters",
        "operationId": "characters_characters_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/process": {
      "post": {
        "summary": "Process",
        "operationId": "process_process_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/world_state": {
      "get": {
        "summary": "Get World State",
        "description": "Get current world state flags.",
        "operationId": "get_world_state_world_state_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      },
      "post": {
        "summary": "Set World State",
        "description": "Set world state flags for all cognitive engines.",
        "operationId": "set_world_state_world_state_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "type": "object",
                "title": "Flags"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/cognitive_stats": {
      "get": {
        "summary": "Cognitive Stats",
        "description": "Get statistics from all active cognitive engines.",
        "operationId": "cognitive_stats_cognitive_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "QuadBrainArbitration": {
        "type": "object",
        "title": "QuadBrainArbitration",
        "description": "Serialized four-brain arbitration emitted inside CognitiveHypervisorTrace.quad_brain when the Synthesus 5 hypervisor selects route=quad_brain_path.",
        "required": [
          "schema",
          "trace_id",
          "selected_response",
          "selected_source",
          "outputs",
          "serial_order",
          "state_contract",
          "latency_ms"
        ],
        "properties": {
          "schema": {
            "type": "string",
            "const": "synthesus.chal.quad_brain_arbitration.v1",
            "description": "Trace schema identifier emitted by QuadBrainArbitration."
          },
          "trace_id": {
            "type": "string"
          },
          "selected_response": {
            "type": "string",
            "description": "Response selected by critic/metacognition or the bridge fallback."
          },
          "selected_source": {
            "type": "string",
            "enum": [
              "critic_metacognition",
              "hemisphere_bridge_fallback"
            ]
          },
          "outputs": {
            "type": "array",
            "description": "Serialized outputs for knowledge, executive, CGPU, and critic roles in fixed arbitration order.",
            "items": {
              "type": "object",
              "required": [
                "role",
                "device",
                "content",
                "confidence"
              ],
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "knowledge_grounding",
                    "executive_reasoning",
                    "cgpu_rendering",
                    "critic_metacognition"
                  ]
                },
                "device": {
                  "type": "string"
                },
                "content": {
                  "type": "object",
                  "additionalProperties": true
                },
                "confidence": {
                  "type": "number"
                },
                "trace": {
                  "type": "object",
                  "additionalProperties": true
                },
                "warnings": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "serial_order": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "knowledge_grounding",
                "executive_reasoning",
                "cgpu_rendering",
                "critic_metacognition"
              ]
            }
          },
          "state_contract": {
            "type": "object",
            "required": [
              "topology",
              "parallel_brain_spawn",
              "serialized_arbitration",
              "template_leakage_allowed",
              "route"
            ],
            "properties": {
              "topology": {
                "type": "string",
                "const": "knowledge->executive->cgpu->critic"
              },
              "parallel_brain_spawn": {
                "type": "boolean",
                "const": false
              },
              "serialized_arbitration": {
                "type": "boolean",
                "const": true
              },
              "template_leakage_allowed": {
                "type": "boolean"
              },
              "bridge_trace_id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "route": {
                "type": "string",
                "const": "quad_brain_path"
              }
            },
            "additionalProperties": true
          },
          "latency_ms": {
            "type": "number"
          }
        }
      },
      "QueryRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query",
            "default": ""
          },
          "q": {
            "type": "string",
            "title": "Q",
            "default": ""
          },
          "text": {
            "type": "string",
            "title": "Text",
            "default": ""
          },
          "stream": {
            "type": "boolean",
            "title": "Stream",
            "default": false
          },
          "context": {
            "type": "string",
            "title": "Context",
            "default": ""
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "default": "left",
            "description": "Processing mode: auto|chal|cognitive|rag|pattern. Use chal to route explicitly through the Synthesus 5 Cognitive Hypervisor; auto preserves the legacy-compatible production pipeline."
          },
          "character": {
            "type": "string",
            "title": "Character",
            "default": ""
          },
          "player_id": {
            "type": "string",
            "title": "Player Id",
            "default": "default"
          }
        },
        "type": "object",
        "title": "QueryRequest"
      },
      "QueryResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "module": {
            "type": "string",
            "title": "Module"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "kernel",
            "description": "Runtime source that produced the response, such as zo_kernel, symbolic_core, cognitive_hypervisor, cognitive, synthesus_master, rag, or fallback."
          },
          "character": {
            "type": "string",
            "title": "Character",
            "default": ""
          },
          "pattern_id": {
            "type": "string",
            "title": "Pattern Id",
            "default": ""
          },
          "emotion": {
            "type": "string",
            "title": "Emotion",
            "default": ""
          },
          "relationship": {
            "additionalProperties": true,
            "type": "object",
            "title": "Relationship",
            "default": {}
          },
          "debug": {
            "additionalProperties": true,
            "type": "object",
            "title": "Debug",
            "default": {},
            "description": "Optional implementation telemetry returned only when include_debug is true. Current keys include kernel_triggered, symbolic_triggered, trace, rag, ml_swarm, cognitive_hypervisor, and fallback diagnostics. For explicit mode=chal calls, cognitive_hypervisor follows the CognitiveHypervisorTrace OpenAPI component, including typed QuadBrainArbitration records when route=quad_brain_path. CGPU candidate-set trace records should also live here as the runtime wiring expands without changing the stable response envelope."
          }
        },
        "type": "object",
        "required": [
          "response",
          "confidence",
          "module"
        ],
        "title": "QueryResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "CGPUFrame": {
        "type": "object",
        "title": "CGPUFrame",
        "description": "CHAL input frame for the chal://cgpu/render device implemented in packages/reasoning/generation/cgpu.py.",
        "required": [
          "frame_id",
          "trace_id",
          "query",
          "plan"
        ],
        "properties": {
          "frame_id": {
            "type": "string"
          },
          "trace_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "plan": {
            "additionalProperties": true,
            "type": "object",
            "description": "Serialized ResponsePlan with intent, safety level, key points, required phrases, forbidden phrases, and domain/style constraints."
          },
          "grounded_state": {
            "additionalProperties": true,
            "type": "object"
          },
          "mode": {
            "type": "string",
            "default": "general",
            "description": "Render mode such as general, npc, persona, dialogue, business, or business_bot."
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "critic_passes": {
            "type": "integer",
            "minimum": 0,
            "default": 1
          },
          "constraints": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "persona": {
            "additionalProperties": true,
            "type": "object"
          },
          "provenance": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          }
        }
      },
      "CGPUOutputFrame": {
        "type": "object",
        "title": "CGPUOutputFrame",
        "description": "Candidate-set output from the chal://cgpu/render device. The selected text is still subject to hypervisor or arbiter safety approval.",
        "required": [
          "frame_id",
          "parent_frame_id",
          "trace_id",
          "device",
          "kind",
          "candidates",
          "confidence",
          "cost",
          "trace"
        ],
        "properties": {
          "frame_id": {
            "type": "string"
          },
          "parent_frame_id": {
            "type": "string"
          },
          "trace_id": {
            "type": "string"
          },
          "device": {
            "type": "string",
            "const": "chal://cgpu/render"
          },
          "kind": {
            "type": "string",
            "const": "candidate_set"
          },
          "candidates": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "selected_candidate_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "selected_text": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "cost": {
            "additionalProperties": true,
            "type": "object"
          },
          "trace": {
            "additionalProperties": true,
            "type": "object",
            "description": "Includes mode, constraints, provenance, grounding_required, and safety_arbitration_required."
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        }
      },
      "CognitiveHypervisorTrace": {
        "properties": {
          "schema": {
            "type": "string",
            "const": "synthesus.chal.hypervisor_trace.v1",
            "description": "Trace schema identifier emitted by CognitiveHypervisor."
          },
          "trace_id": {
            "type": "string"
          },
          "route": {
            "type": "string",
            "enum": [
              "fast_path",
              "grounded_path",
              "deep_reasoning_path",
              "quad_brain_path",
              "safety_path"
            ]
          },
          "hemisphere_mode": {
            "type": "string"
          },
          "latency_ms": {
            "type": "number"
          },
          "budget": {
            "type": "object",
            "properties": {
              "latency_ms": {
                "type": "number"
              },
              "retrieval_depth": {
                "type": "integer"
              },
              "candidate_count": {
                "type": "integer"
              },
              "critic_passes": {
                "type": "integer"
              }
            },
            "required": [
              "latency_ms",
              "retrieval_depth",
              "candidate_count",
              "critic_passes"
            ],
            "additionalProperties": true
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bridge_latency_ms": {
            "type": "number"
          },
          "device_isolation": {
            "type": "object",
            "additionalProperties": true,
            "description": "AIVM execution guard result for the CHAL device dispatch."
          },
          "budget_exhausted": {
            "type": "boolean"
          },
          "degraded": {
            "type": "boolean"
          },
          "template_guard": {
            "type": "object",
            "additionalProperties": true,
            "description": "Template leakage guard decision and matched signatures."
          },
          "quad_brain": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/QuadBrainArbitration"
              },
              {
                "type": "null"
              }
            ],
            "description": "Serialized Quad Brain arbitration trace when route is quad_brain_path; null otherwise."
          }
        },
        "type": "object",
        "required": [
          "schema",
          "trace_id",
          "route",
          "hemisphere_mode",
          "latency_ms",
          "budget",
          "reasons",
          "constraints",
          "device_isolation",
          "budget_exhausted",
          "degraded",
          "template_guard"
        ],
        "title": "CognitiveHypervisorTrace",
        "description": "Debug trace emitted under QueryResponse.debug.cognitive_hypervisor for explicit mode=chal requests."
      }
    }
  }
}
