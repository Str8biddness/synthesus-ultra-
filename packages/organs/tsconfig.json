{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "types": ["node", "jest"],

    "paths": {
      "@/*": ["./frontend/src/*"]
    }
  },
  "include": ["frontend/src", "synthetic_core", "amplification", "domains", "utils", "tests", "scripts", "organs"]
}
